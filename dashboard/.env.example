# Copy to .env (dashboard/.env). Only you (admin) use this when running the dashboard locally.
# Do not set these in production; the Train tab and API are local-only.

# Show "Train your own SJM" tab (admin only). Set to true only in your local .env.
NEXT_PUBLIC_ENABLE_TRAIN_TAB=

# Train API runs only when request is from localhost, or when this is true. Leave unset for local-only.
# ALLOW_TRAIN_API=true

# Python for training: your conda env so numpy/pandas/etc. are available.
# Option A: set full path, e.g. from: conda activate <your_env> && which python
# HELIX_PYTHON=/opt/homebrew/Caskroom/miniconda/base/envs/helix/bin/python
# Option B: start the dashboard with conda activated (cd dashboard && conda activate <env> && npm run dev);
#   then CONDA_PREFIX is set and the API will use $CONDA_PREFIX/bin/python automatically.
HELIX_PYTHON=

# Default backtest JSON loaded by the dashboard (file must exist in dashboard/public/).
# Override at runtime: npm run dev -- --config backtest_data.json
NEXT_PUBLIC_BACKTEST_JSON=backtest_data_asymmetric.json
